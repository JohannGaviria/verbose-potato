# --- Application ---
APP_NAME=Verbose Potato
APP_SUMMARY=REST API for library management
APP_DESCRIPTION=Verbose Potato is a REST API for library management, developed as a practice project to apply Hexagonal Architecture (Ports & Adapters).
APP_VERSION=0.0.0

# --- Backend ---
DEBUG=True
ENVIRONMENT=development
BACKEND_PORT=8000
BACKEND_WORKERS=4
CORS_ALLOW_ORIGINS=http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=verbose_potato
POSTGRES_PORT=5432

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/verbose_potato
DATABASE_URL_ALEMBIC=postgresql+psycopg2://postgres:password@postgres:5432/verbose_potato
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_DB=0
REDIS_HOST=redis
REDIS_PASSWORD=password
REDIS_PORT=6379
REDIS_MAX_CONNECTIONS=20
REDIS_DECODE_RESPONSES=true
